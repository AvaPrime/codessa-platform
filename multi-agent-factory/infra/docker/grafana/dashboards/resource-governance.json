{
  "dashboard": {
    "id": null,
    "title": "Resource Governance Dashboard",
    "tags": ["governance", "resources", "costs"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Resource Utilization Overview",
        "type": "stat",
        "targets": [
          {
            "expr": "avg(resource_usage_ratio{resource_type=\"cpu\"})",
            "legendFormat": "CPU Utilization"
          },
          {
            "expr": "avg(resource_usage_ratio{resource_type=\"memory\"})",
            "legendFormat": "Memory Utilization"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "thresholds": {
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 0.7},
                {"color": "red", "value": 0.9}
              ]
            }
          }
        }
      },
      {
        "id": 2,
        "title": "Cost Tracking",
        "type": "timeseries",
        "targets": [
          {
            "expr": "sum(cost_usd{cost_type=\"total\"}) by (service)",
            "legendFormat": "{{service}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD"
          }
        }
      },
      {
        "id": 3,
        "title": "Budget Burn Rate",
        "type": "gauge",
        "targets": [
          {
            "expr": "sum(cost_usd{cost_type=\"total\"}) / 5000",
            "legendFormat": "Budget Usage"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "max": 1,
            "thresholds": {
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 0.75},
                {"color": "red", "value": 0.9}
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "Quota Usage by Tenant",
        "type": "table",
        "targets": [
          {
            "expr": "quota_usage_ratio",
            "format": "table",
            "instant": true
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {"Time": true, "__name__": true},
              "renameByName": {
                "tenant": "Tenant",
                "quota_type": "Quota Type",
                "Value": "Usage %"
              }
            }
          }
        ]
      },
      {
        "id": 5,
        "title": "SLA Compliance",
        "type": "stat",
        "targets": [
          {
            "expr": "sla_compliance_ratio{sla_type=\"availability\"}",
            "legendFormat": "Availability"
          },
          {
            "expr": "sla_compliance_ratio{sla_type=\"performance\"}",
            "legendFormat": "Performance"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "thresholds": {
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 0.95},
                {"color": "green", "value": 0.99}
              ]
            }
          }
        }
      }
    ],
    "time": {
      "from": "now-24h",
      "to": "now"
    },
    "refresh": "30s"
  }
}